{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "QueryRequest": {
        "description": "Body for a natural-language orchestration request.",
        "properties": {
          "conversation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Conversation Id"
          },
          "query": {
            "minLength": 1,
            "title": "Query",
            "type": "string"
          }
        },
        "required": [
          "query"
        ],
        "title": "QueryRequest",
        "type": "object"
      },
      "QueryResponse": {
        "description": "Full result of handling a query through the pipeline.",
        "properties": {
          "answer": {
            "title": "Answer",
            "type": "string"
          },
          "conversation_id": {
            "title": "Conversation Id",
            "type": "string"
          },
          "intent": {
            "additionalProperties": true,
            "title": "Intent",
            "type": "object"
          },
          "needs_clarification": {
            "title": "Needs Clarification",
            "type": "boolean"
          },
          "pending_action": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pending Action"
          },
          "plan": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Plan",
            "type": "array"
          },
          "results": {
            "additionalProperties": true,
            "title": "Results",
            "type": "object"
          }
        },
        "required": [
          "answer",
          "conversation_id",
          "intent",
          "plan",
          "results",
          "needs_clarification",
          "pending_action"
        ],
        "title": "QueryResponse",
        "type": "object"
      },
      "SyncServiceStatus": {
        "description": "Per-service sync bookkeeping snapshot.",
        "properties": {
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "items_synced": {
            "title": "Items Synced",
            "type": "integer"
          },
          "last_synced_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Synced At"
          },
          "service": {
            "title": "Service",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "service",
          "status",
          "last_synced_at",
          "items_synced",
          "error"
        ],
        "title": "SyncServiceStatus",
        "type": "object"
      },
      "SyncStatusResponse": {
        "description": "Sync status across all workspace services.",
        "properties": {
          "statuses": {
            "items": {
              "$ref": "#/components/schemas/SyncServiceStatus"
            },
            "title": "Statuses",
            "type": "array"
          }
        },
        "required": [
          "statuses"
        ],
        "title": "SyncStatusResponse",
        "type": "object"
      },
      "SyncTriggerResponse": {
        "description": "Result of triggering a sync (inline or via Celery).",
        "properties": {
          "mode": {
            "title": "Mode",
            "type": "string"
          },
          "task_ids": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "title": "Task Ids",
            "type": "object"
          }
        },
        "required": [
          "mode",
          "task_ids"
        ],
        "title": "SyncTriggerResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Workspace Orchestrator",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/google": {
      "get": {
        "description": "Redirect to Google's consent screen (400 if OAuth is unconfigured).",
        "operationId": "google_auth_api_v1_auth_google_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Google Auth",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/google/callback": {
      "get": {
        "description": "Exchange the auth ``code`` for tokens and upsert the user's credentials.",
        "operationId": "google_callback_api_v1_auth_google_callback_get",
        "parameters": [
          {
            "in": "query",
            "name": "code",
            "required": true,
            "schema": {
              "title": "Code",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Google Callback Api V1 Auth Google Callback Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Google Callback",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/query": {
      "post": {
        "description": "Classify, plan, execute and synthesize a response for ``body.query``.",
        "operationId": "handle_query_api_v1_query_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Handle Query",
        "tags": [
          "query"
        ]
      }
    },
    "/api/v1/sync/status": {
      "get": {
        "description": "Return the per-service sync state for the current user.",
        "operationId": "sync_status_api_v1_sync_status_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyncStatusResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Sync Status",
        "tags": [
          "sync"
        ]
      }
    },
    "/api/v1/sync/trigger": {
      "post": {
        "description": "Kick off syncs for the current user.\n\n``inline=true`` runs all three service syncs synchronously in worker\nthreads (each task internally drives its own event loop) and returns\n``mode=\"inline\"``. Otherwise the syncs are dispatched as a Celery group and\nthe group/task ids are returned as strings.",
        "operationId": "trigger_sync_api_v1_sync_trigger_post",
        "parameters": [
          {
            "in": "query",
            "name": "inline",
            "required": false,
            "schema": {
              "default": false,
              "title": "Inline",
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyncTriggerResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Trigger Sync",
        "tags": [
          "sync"
        ]
      }
    },
    "/healthz": {
      "get": {
        "description": "Liveness probe.",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Healthz Healthz Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Healthz"
      }
    }
  }
}
