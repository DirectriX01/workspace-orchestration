# Async (asyncpg) database URL used by the FastAPI app
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/orchestrator
# Sync (psycopg) database URL used by Alembic and Celery workers
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/orchestrator
# Redis URL for caching and Celery broker/result backend
REDIS_URL=redis://localhost:6380/0
# OpenAI API key (leave empty to use the fake providers for local dev)
OPENAI_API_KEY=
# LLM provider: "openai" | "fake"
LLM_PROVIDER=openai
# Embeddings provider: "openai" | "fake"
EMBEDDINGS_PROVIDER=openai
# Chat completion model name
LLM_MODEL=gpt-4o-mini
# Embedding model name
EMBEDDING_MODEL=text-embedding-3-small
# Use mock Google clients instead of real Gmail/Calendar/Drive APIs
MOCK_GOOGLE=true
# Default timezone for resolving relative dates
DEFAULT_TZ=Asia/Kolkata
# Google OAuth client id
GOOGLE_CLIENT_ID=
# Google OAuth client secret
GOOGLE_CLIENT_SECRET=
# Google OAuth redirect URI
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# Email of the seeded demo user
DEMO_USER_EMAIL=demo@example.com
